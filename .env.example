# Example values only. Copy this file to .env and customize for your environment.
# .env is the active file used by scripts/render-config.py and docker compose.

TRINO_VERSION=477
TRINO_SINGLE_PORT=8080
TRINO_HTTP_PORT=8080
TZ=America/Sao_Paulo

POSTGRES_DB=postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme

NESSIE_HOST=nessie
NESSIE_PORT=19120
NESSIE_HTTP_PORT=19120
NESSIE_VERSION_STORE_TYPE=JDBC
NESSIE_CATALOG_URI=http://nessie:19120/api/v2
NESSIE_DATASOURCE_JDBC_URL=jdbc:postgresql://postgres:5432/nessie
NESSIE_DATASOURCE_USERNAME=admin
NESSIE_DATASOURCE_PASSWORD=changeme

ICEBERG_REF=main
ICEBERG_WAREHOUSE_DIR=s3://lakehouse/
S3_ENDPOINT=http://minio:9000
S3_AWS_ACCESS_KEY=admin
S3_AWS_SECRET_KEY=changeme
S3_REGION=us-east-1

POSTGRESQL_CONNECTION_URL=jdbc:postgresql://postgres:5432/lab
POSTGRESQL_CONNECTION_USER=admin
POSTGRESQL_CONNECTION_PASSWORD=changeme